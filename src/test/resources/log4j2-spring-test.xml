<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="warn">
    <Properties>
        <Property name="CONSOLE_LOG_PATTERN">
            <![CDATA[[%d{HH:mm:ss.SSS}] %highlight{%-5p}{FATAL=red, ERROR=red, WARN=yellow, INFO=green, DEBUG=blue} [%t] %style{%c{1.}}{cyan} - %m%n%ex]]>
        </Property>
    </Properties>
    <Appenders>
        <Console name="CONSOLE" target="SYSTEM_OUT" follow="true">
            <PatternLayout pattern="${CONSOLE_LOG_PATTERN}"/>
        </Console>
    </Appenders>
    <Loggers>
        <Root level="info">
            <AppenderRef ref="CONSOLE"/>
        </Root>
        <Logger name="com.gomo.app" level="debug" additivity="false">
            <AppenderRef ref="CONSOLE"/>
        </Logger>
        <!-- DB 쿼리 파라미터를 보기 위해 Hibernate 로그 레벨 조정 -->
        <Logger name="org.hibernate.type.descriptor.sql" level="trace" additivity="false">
            <AppenderRef ref="CONSOLE"/>
        </Logger>
    </Loggers>
</Configuration>
