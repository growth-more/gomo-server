<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="${sys:log4j.configuration.status:-WARN}"> <!-- use java system property for log4j2 status in local or dev-->
    <Properties>
        <Property name="p_profile">${spring:spring.profiles.active:-local}</Property>
        <Property name="p_pid">${sys:PID}</Property>
        <Property name="FILE_DIR">./logs</Property>
        <Property name="CONSOLE_LOG_LEVEL">{%5p}{FATAL=red blink, ERROR=red bold, WARN=yellow bold, INFO=green bold, DEBUG=blue bold, TRACE=blue}</Property>

        <Property name="CONSOLE_LOG_PATTERN">
            <![CDATA[[%mdc{REQUEST_ID}] %d{HH:mm:ss.SSS} %style{${p_profile}}{magenta} ${p_pid} %highlight${CONSOLE_LOG_LEVEL} [%t] %style{%c{1.}}{cyan} --- %m%n%ex]]>
        </Property>
        <Property name="FILE_LOG_PATTERN">
            <![CDATA[[%mdc{REQUEST_ID}] %d{yyyy-MM-dd HH:mm:ss.SSS} ${p_profile} ${p_pid} %-5level [%t] %c{1.} --- %m%n%ex]]>
        </Property>
    </Properties>

    <Appenders>
        <Console name="CONSOLE" target="SYSTEM_OUT">
            <PatternLayout pattern="${CONSOLE_LOG_PATTERN}"/>
        </Console>

        <RollingFile name="INFO_FILE" fileName="${FILE_DIR}/gomo.log" filePattern="${FILE_DIR}/gomo.%d{yyyy-MM-dd}.%i.log.gz">
            <PatternLayout>
                <Pattern>${FILE_LOG_PATTERN}</Pattern>
            </PatternLayout>
            <Policies>
                <!-- modulate="true": Adjusts the rollover time to occur precisely at midnight, rather than at the application start time. -->
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="100 MB"/>
            </Policies>
            <DefaultRolloverStrategy max="30">
                <Delete basePath="${FILE_DIR}" maxDepth="1">
                    <IfFileName glob="gomo.*.log.gz"/>
                    <IfLastModified age="30d"/>
                    <IfAccumulatedFileSize exceeds="10 GB"/>
                </Delete>
            </DefaultRolloverStrategy>
            <Filters>
                <ThresholdFilter level="INFO" onMatch="ACCEPT" onMismatch="DENY"/>
            </Filters>
        </RollingFile>

        <RollingFile name="DEBUG_FILE" fileName="${FILE_DIR}/gomo-debug.log"
                     filePattern="${FILE_DIR}/gomo-debug.%d{yyyy-MM-dd}.%i.log.gz">
            <PatternLayout>
                <Pattern>${FILE_LOG_PATTERN}</Pattern>
            </PatternLayout>
            <Policies>
                <TimeBasedTriggeringPolicy/>
                <SizeBasedTriggeringPolicy size="100 MB"/>
            </Policies>
            <DefaultRolloverStrategy max="7">
                <Delete basePath="${FILE_DIR}" maxDepth="1">
                    <IfFileName glob="gomo-debug.*.log.gz"/>
                    <IfLastModified age="7d"/>
                    <IfAccumulatedFileSize exceeds="10 GB"/>
                </Delete>
            </DefaultRolloverStrategy>
            <Filters>
                <LevelMatchFilter level="DEBUG" onMatch="ACCEPT" onMismatch="DENY"/>
            </Filters>
        </RollingFile>

        <RollingFile name="TRACE_FILE" fileName="${FILE_DIR}/gomo-trace.log"
                     filePattern="${FILE_DIR}/gomo-trace.%d{yyyy-MM-dd}.%i.log.gz">
            <PatternLayout>
                <Pattern>${FILE_LOG_PATTERN}</Pattern>
            </PatternLayout>
            <Policies>
                <TimeBasedTriggeringPolicy/>
                <SizeBasedTriggeringPolicy size="100 MB"/>
            </Policies>
            <DefaultRolloverStrategy max="7">
                <Delete basePath="${FILE_DIR}" maxDepth="1">
                    <IfFileName glob="gomo-trace.*.log.gz"/>
                    <IfLastModified age="7d"/>
                    <IfAccumulatedFileSize exceeds="10 GB"/>
                </Delete>
            </DefaultRolloverStrategy>
            <Filters>
                <LevelMatchFilter level="TRACE" onMatch="ACCEPT" onMismatch="DENY"/>
            </Filters>
        </RollingFile>
    </Appenders>

    <Loggers>
        <SpringProfile name="local">
            <Root level="info">
                <AppenderRef ref="CONSOLE"/>
            </Root>
            <Logger name="com.gomo.app" level="trace" additivity="false">
                <AppenderRef ref="CONSOLE"/>
            </Logger>
        </SpringProfile>

        <SpringProfile name="dev">
            <Root level="info">
                <AppenderRef ref="CONSOLE"/>
                <AppenderRef ref="INFO_FILE"/>
            </Root>
            <Logger name="com.gomo.app" level="trace" additivity="false">
                <AppenderRef ref="CONSOLE"/>
                <AppenderRef ref="INFO_FILE"/>
                <AppenderRef ref="DEBUG_FILE"/>
                <AppenderRef ref="TRACE_FILE"/>
            </Logger>
        </SpringProfile>

        <SpringProfile name="prod">
            <Root level="info">
                <AppenderRef ref="CONSOLE"/>
                <AppenderRef ref="INFO_FILE"/>
            </Root>
            <Logger name="com.gomo.app" level="info" additivity="false">
                <AppenderRef ref="CONSOLE"/>
                <AppenderRef ref="INFO_FILE"/>
                <AppenderRef ref="DEBUG_FILE"/>
                <AppenderRef ref="TRACE_FILE"/>
            </Logger>
            <Logger name="com.gomo.app.logging" level="trace" additivity="false">
                <AppenderRef ref="CONSOLE"/>
                <AppenderRef ref="INFO_FILE"/>
                <!--<AppenderRef ref="DEBUG_FILE"/>-->
                <AppenderRef ref="TRACE_FILE"/>
            </Logger>
        </SpringProfile>
    </Loggers>
</Configuration>
