{
  "openapi": "3.0.1",
  "info": {
    "title": "GOMO API",
    "description": "GOMO API 문서 입니다.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080"
    }
  ],
  "tags": [],
  "paths": {
    "/interests": {
      "post": {
        "tags": [
          "Interest"
        ],
        "summary": "관심사 등록 API",
        "description": "사용자의 관심사를 등록합니다.",
        "operationId": "create_interest",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "request": {
                    "$ref": "#/components/schemas/CreateInterestRequest"
                  },
                  "logo": {
                    "type": "string",
                    "format": "binary",
                    "description": "업로드할 로고 이미지"
                  }
                },
                "required": [
                  "request",
                  "logo"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "201",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateInterestResponse"
                },
                "examples": {
                  "create_interest": {
                    "value": "{\"id\":\"01949df8-f62f-7f5a-a4ff-d9f07ac4ec52\"}"
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "cookieAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "CreateInterestRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "관심사의 이름"
          },
          "description": {
            "type": "string",
            "description": "관심사에 대한 설명"
          }
        },
        "required": [
          "name"
        ]
      },
      "CreateInterestResponse": {
        "title": "CreateInterestResponse",
        "required": [
          "id"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "관심사 아이디: 임의의 고유 식별 문자"
          }
        }
      }
    },
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "Access-Token"
      }
    }
  },
  "security": [
    {
      "cookieAuth": []
    }
  ]
}